# === Core Configuration (Required) ===
DEFAULT_MODEL=deepseek-v4-flash
OPENAI_API_KEY=your_openai_api_key_here

# === API Base URLs ===
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_BASE=https://api.deepseek.com

# === Search & Crawl Tools (Required for GAIA agent runs) ===
SERPER_API_KEY=your_serper_api_key_here

# Web crawling - choose ONE:
# Option 1: JinaAI
# JINA_API_KEY=your_jina_api_key_here
# WEB_ACCESS_PROVIDER=jina

# Option 2: crawl4ai (free, no API key)
WEB_ACCESS_PROVIDER=crawl4ai

# === Optional: Override specific models ===
ANALYSIS_MODEL=deepseek-v4-flash
GENERATION_MODEL=deepseek-v4-flash
MSWEA_MODEL_NAME=deepseek-v4-flash
DEFAULT_JUDGE_MODEL=deepseek-v4-flash
